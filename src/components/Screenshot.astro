---
import { Picture } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  src: ImageMetadata | string
  darkSrc?: ImageMetadata
  alt: string
  class?: string
  [key: string]: unknown
}

const { src, darkSrc, alt, class: className, ...rest } = Astro.props

// Eagerly load all auto-generated screenshot PNGs for string-based lookups (MDX files)
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/**/*.png',
  { eager: true }
)

let image: ImageMetadata
let darkImage: ImageMetadata | null = null

if (typeof src === 'string') {
  // String src: resolve from help directory by filename
  const imagePath = `/src/assets/images/help/${src}.png`
  const resolved = images[imagePath]?.default
  if (!resolved) {
    throw new Error(`Screenshot: image not found: ${imagePath}`)
  }
  image = resolved

  // Auto-discover dark variant by convention
  const darkImagePath = `/src/assets/images/help/${src}-dark.png`
  darkImage = images[darkImagePath]?.default ?? null
} else {
  // ImageMetadata src: use directly (from ESM imports in .astro files)
  image = src
  darkImage = darkSrc ?? null
}

// Screenshots are captured at 2x DPR, so natural width is 2x display width
const displayWidth = Math.round(image.width / 2)
const darkDisplayWidth = darkImage ? Math.round(darkImage.width / 2) : 0
const hasDarkVariant = darkImage !== null
---

{hasDarkVariant ? (
  <>
    <span class="dark:hidden">
      <Picture
        src={image}
        width={displayWidth}
        formats={['avif', 'webp']}
        fallbackFormat="png"
        quality={95}
        densities={[1, 2]}
        alt={alt}
        class={className}
        {...rest}
      />
    </span>
    <span class="hidden dark:inline">
      <Picture
        src={darkImage!}
        width={darkDisplayWidth}
        formats={['avif', 'webp']}
        fallbackFormat="png"
        quality={95}
        densities={[1, 2]}
        alt={alt}
        class={className}
        {...rest}
      />
    </span>
  </>
) : (
  <Picture
    src={image}
    width={displayWidth}
    formats={['avif', 'webp']}
    fallbackFormat="png"
    quality={95}
    densities={[1, 2]}
    alt={alt}
    class={className}
    {...rest}
  />
)}
