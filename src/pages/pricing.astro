---
import Layout from '../layouts/Layout.astro'
import Plans from '../components/partials/Plans.astro'
import CloudOrSelfHosted from '../components/partials/CloudOrSelfHosted.astro'
import FAQSection from '../components/FAQSection.astro'

const pricingFaqs = [
    {
        question: 'Is the self-hosted version really free?',
        answer: 'Yes. Vikunja is openly licensed under the [AGPLv3](https://code.vikunja.io/api/src/branch/main/LICENSE). You can self-host it for personal use or for your entire company at no cost. All core features are included.',
    },
    {
        question: 'What does Vikunja Cloud give me that self-hosting doesn\'t?',
        answer: 'The same features, minus the ops work. We handle hosting, backups, updates, and TLS. You get a managed instance hosted in the EU, so you can focus on your tasks instead of your infrastructure.',
    },
    {
        question: 'Who is the Enterprise plan for?',
        answer: 'Teams that need a dedicated instance, a GDPR data processing agreement, admin tools to manage users, or the option to run Vikunja on their own server with our support. You don\'t need 500 employees to unlock these features \u2014 they\'re available at any team size.',
    },
    {
        question: 'Can I try before I buy?',
        answer: 'Every Cloud plan comes with a free 14-day trial. Cancel anytime. You can also [try the live demo](https://try.vikunja.io/demo-account-create/) right now without signing up.',
    },
    {
        question: 'Can I switch from self-hosted to Cloud (or the other way around)?',
        answer: 'Yes. You can export your data and import it into another instance. If you need help migrating, [reach out](mailto:hello@vikunja.io) and we\'ll walk you through it.',
    },
    {
        question: 'I\'m already self-hosting. How do I bring Vikunja to my team at work?',
        answer: 'Check out the [Convince Your Boss](/convince) page \u2014 it has everything you need to make the case internally.',
    },
]
---
<Layout title="Pricing" description="Vikunja pricing for individuals, teams, and enterprises. Self-host for free or let us run it for you. Enterprise features without the enterprise price tag.">
    <main class="max-w-(--breakpoint-xl) mx-auto px-4 md:px-0">
        <div class="pt-32 pb-8 px-4 text-center">
            <h1 class="text-4xl font-display">
                Simple, honest pricing.
            </h1>
            <p class="mt-4 text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto text-balance">
                Self-host Vikunja for free, forever. Or let us handle the infrastructure so you can focus on your tasks.
            </p>
        </div>

        <Plans />

        <section class="mt-24 mb-16">
            <h2 class="font-display text-3xl text-center mb-12">Self-Hosted vs. Cloud vs. Enterprise</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="py-3 px-4 font-display text-lg"></th>
                            <th class="py-3 px-4 font-display text-lg">Self-Hosted (Free)</th>
                            <th class="py-3 px-4 font-display text-lg">Cloud</th>
                            <th class="py-3 px-4 font-display text-lg">Enterprise</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-700 dark:text-gray-300">
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">Unlimited tasks & projects</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">List, Kanban, Gantt, Table views</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">Reminders & repeating tasks</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">Labels, filters, saved views</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">Teams & shared projects</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Organization plan</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">CalDAV integration</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">Import from Todoist, Trello, MS To-Do</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">Managed hosting & updates</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">Yes</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">Priority email support</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">Organization plan</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">Dedicated instance</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">Admin interface</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">Bring your own server</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">GDPR data processing agreement</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-3 px-4 font-medium">Unlimited attachment storage</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                        <tr>
                            <td class="py-3 px-4 font-medium">Team training</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">&mdash;</td>
                            <td class="py-3 px-4">Yes</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <FAQSection faqs={pricingFaqs} />

        <div class="pb-20 flex items-center justify-center flex-col text-center">
            <h2 class="font-display text-3xl mb-8">Get Started</h2>
            <CloudOrSelfHosted />
        </div>
    </main>
</Layout>
