---
import Layout from '../layouts/Layout.astro'
import Button from '../components/Button.astro'
import FAQSection from '../components/FAQSection.astro'

const enterpriseFaqs = [
    {
        question: 'Is this open core?',
        answer: 'No. The existing Vikunja stays exactly as it is — nothing is being taken away or locked behind a paywall. Enterprise adds new features (like audit logs and an admin panel) and services (support, compliance) on top. All of it is AGPLv3.',
    },
    {
        question: 'What if I stop paying?',
        answer: 'Vikunja itself keeps working — your tasks, projects, and data aren\'t going anywhere. The enterprise features (audit logs, admin panel, time tracking) need an active subscription. The core app you and your team use every day does not.',
    },
    {
        question: 'Do I need a minimum number of users?',
        answer: 'No. Your compliance requirements don\'t care how many employees you have. Neither does our pricing.',
    },
    {
        question: 'Can I self-host and still get enterprise support?',
        answer: 'Yes. That\'s the whole point. Run Vikunja on your infrastructure, with our support behind it.',
    },
    {
        question: 'I\'m already self-hosting Vikunja for free. What changes?',
        answer: 'Nothing has to change. The free self-hosted version isn\'t going anywhere. Enterprise is for teams that need vendor support, compliance paperwork, or admin tooling on top of what\'s already there.',
    },
    {
        question: 'Is this a sell-out?',
        answer: 'No. This is how the project stays sustainable without VC money, ads, or selling your data. Companies that use Vikunja can now support it through a channel they already understand: buying software. Every subscription funds continued development of the same open-source project everyone uses.',
    },
    {
        question: 'How is this different from Vikunja Cloud?',
        answer: 'Vikunja Cloud is shared hosting for individuals and small teams. Enterprise gives you a dedicated instance (managed by us or on your server), admin tooling, audit logs, time tracking, and a GDPR data processing agreement. Different needs, different offering.',
    },
]
---
<Layout title="Vikunja Enterprise" description="Same open-source Vikunja, with support, compliance, and admin tooling your company needs. AGPLv3 licensed. No vendor lock-in. No minimum seat count.">
    <main class="max-w-(--breakpoint-xl) mx-auto px-4 md:px-0">

        <!-- Hero -->
        <div class="pt-32 pb-8 px-4 text-center">
            <h1 class="text-4xl md:text-5xl font-display text-balance">
                Same open-source Vikunja.<br/>
                With someone to call.
            </h1>
            <p class="mt-6 text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto text-balance">
                Your team needs a task manager. Your compliance team needs paperwork.
                Your IT team needs support.
                Vikunja Enterprise is all three — same AGPLv3 license, same codebase,
                with a vendor relationship your procurement department actually knows how to handle.
            </p>
            <div class="mt-8">
                <Button href="https://console.vikunja.io/register">
                    Join the waitlist
                </Button>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">
                    Now in private beta.
                </p>
            </div>
        </div>

        <!-- The pitch -->
        <section class="max-w-3xl mx-auto mt-20 px-4">
            <div class="bg-gray-50 dark:bg-gray-800 rounded-sm p-8 text-lg text-gray-700 dark:text-gray-300">
                <p>
                    Companies know how to buy software. They have procurement departments,
                    purchase orders, and vendor approval processes.
                    What they don't have is a way to donate to an open-source project
                    and get an invoice and someone to call when something breaks.
                </p>
                <p class="mt-4">
                    That's what Vikunja Enterprise is.
                    The same Vikunja you already know — plus features like audit logs, an admin panel,
                    and time tracking that companies need, along with support, compliance paperwork,
                    and someone to call.
                </p>
            </div>
        </section>

        <!-- What you get -->
        <section class="max-w-5xl mx-auto mt-24 px-4">
            <h2 class="font-display text-3xl text-center mb-12">What you get</h2>

            <div class="grid md:grid-cols-3 gap-8">
                <div class="border border-gray-100 dark:border-gray-800 rounded-sm p-6">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <h3 class="font-display text-xl mb-2">Admin panel</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        Manage users, teams, and permissions from a central interface.
                        No more poking at the database.
                    </p>
                </div>

                <div class="border border-gray-100 dark:border-gray-800 rounded-sm p-6">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <h3 class="font-display text-xl mb-2">Audit logs</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        Real audit trails you can integrate with external systems.
                        Compliance-grade, not decorative.
                    </p>
                </div>

                <div class="border border-gray-100 dark:border-gray-800 rounded-sm p-6">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <h3 class="font-display text-xl mb-2">Time tracking</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        Track time spent on tasks directly in Vikunja.
                        No separate tool, no context switching.
                    </p>
                </div>

                <div class="border border-gray-100 dark:border-gray-800 rounded-sm p-6">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                    </div>
                    <h3 class="font-display text-xl mb-2">Priority support</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        Direct line to the people who build Vikunja.
                        No community forum queue.
                    </p>
                </div>

                <div class="border border-gray-100 dark:border-gray-800 rounded-sm p-6">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>
                    <h3 class="font-display text-xl mb-2">GDPR data processing agreement</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        The paperwork your legal team needs. Signed and ready.
                        EU-hosted, EU-built.
                    </p>
                </div>

                <div class="border border-gray-100 dark:border-gray-800 rounded-sm p-6">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                    </div>
                    <h3 class="font-display text-xl mb-2">Team training</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        Get your team productive fast. Onboarding sessions included
                        so you're not writing internal docs from scratch.
                    </p>
                </div>

                <div class="border border-gray-100 dark:border-gray-800 rounded-sm p-6">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
                        </svg>
                    </div>
                    <h3 class="font-display text-xl mb-2">Dedicated instance</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        Your own Vikunja, managed by us on EU infrastructure.
                        Not a shared tenant — yours.
                    </p>
                </div>

                <div class="border border-gray-100 dark:border-gray-800 rounded-sm p-6">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                        </svg>
                    </div>
                    <h3 class="font-display text-xl mb-2">Bring your own server</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        Run it on your infrastructure. We support it.
                        Your data never leaves your network.
                    </p>
                </div>

                <div class="border border-gray-100 dark:border-gray-800 rounded-sm p-6">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
                        </svg>
                    </div>
                    <h3 class="font-display text-xl mb-2">Unlimited attachments</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        No storage caps. Attach what you need without
                        counting megabytes.
                    </p>
                </div>
            </div>
        </section>

        <!-- Still open source -->
        <section class="max-w-4xl mx-auto mt-24 px-4">
            <h2 class="font-display text-3xl text-center mb-12">Still open source. Still yours.</h2>

            <div class="grid md:grid-cols-2 gap-8">
                <div>
                    <h3 class="font-display text-lg mb-2">Same license</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        AGPLv3. Not "source available." Not "open core."
                        The real thing. Every line of code, publicly auditable.
                    </p>
                </div>
                <div>
                    <h3 class="font-display text-lg mb-2">Enterprise adds, it doesn't take away</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        The free version stays exactly as it is. Enterprise adds features
                        on top — nothing is being removed or paywalled from what's already there.
                    </p>
                </div>
                <div>
                    <h3 class="font-display text-lg mb-2">No lock-in</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        If you cancel, the core app keeps running and your data stays yours.
                        Enterprise features deactivate, but you're never locked out of your own work.
                    </p>
                </div>
                <div>
                    <h3 class="font-display text-lg mb-2">Same community</h3>
                    <p class="text-gray-700 dark:text-gray-300">
                        Bug reports, feature requests, and contributions work exactly
                        the same way. Enterprise customers don't get a separate roadmap.
                    </p>
                </div>
            </div>

            <div class="mt-12 max-w-2xl mx-auto text-center">
                <blockquote class="text-lg italic text-gray-600 dark:text-gray-400">
                    "I built Vikunja because I believe you should own your tools.
                    That doesn't change because your company has a procurement department."
                </blockquote>
                <p class="mt-4 text-gray-700 dark:text-gray-300">
                    <strong>Konrad</strong><br/>
                    <span class="text-sm">Founder of Vikunja</span>
                </p>
            </div>
        </section>

        <!-- Social proof bar -->
        <section class="max-w-4xl mx-auto mt-24 px-4">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
                <div>
                    <div class="font-display text-2xl">AGPLv3</div>
                    <div class="text-sm text-gray-500 dark:text-gray-400">Fully open source</div>
                </div>
                <div>
                    <div class="font-display text-2xl">Since 2018</div>
                    <div class="text-sm text-gray-500 dark:text-gray-400">Actively developed</div>
                </div>
                <div>
                    <div class="font-display text-2xl">EU-built</div>
                    <div class="text-sm text-gray-500 dark:text-gray-400">Made in Germany</div>
                </div>
                <div>
                    <div class="font-display text-2xl">Bootstrapped</div>
                    <div class="text-sm text-gray-500 dark:text-gray-400">Funded by users, not VCs</div>
                </div>
            </div>
        </section>

        <!-- FAQ -->
        <FAQSection faqs={enterpriseFaqs} />

        <!-- CTA -->
        <section class="max-w-3xl mx-auto mb-20 text-center px-4">
            <h2 class="font-display text-3xl mb-4">Now in private beta.</h2>
            <p class="text-lg text-gray-600 dark:text-gray-300 mb-8 text-balance">
                Vikunja Enterprise is currently in private beta.
                Join the waitlist and I'll be in touch.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <Button href="https://console.vikunja.io/register">
                    Join the waitlist
                </Button>
                <Button href="mailto:hello@vikunja.io" class="bg-gray-200! text-gray-800! dark:bg-gray-700! dark:text-gray-200!">
                    Questions? Get in touch
                </Button>
            </div>
        </section>
    </main>
</Layout>
